# Frontend (Vite) — copy to .env.local for local dev if needed
# Base URL for the lead API. Leave empty to use same-origin /api (nginx/Cloudflare routes it).
VITE_API_BASE=

# Dev proxy target for `npm run dev` (used by vite.config.js). Point this at the
# local backend or a deployed API base URL to test the form end to end.
VITE_API_TARGET=http://localhost:8787
