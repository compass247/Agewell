# ============================================================
# PHI portal — local environment template.
# Copy to backend/phi/.env (for docker compose) AND mirror the app-facing
# vars into the repo-root .env.local (for `next dev`). Both files are
# gitignored. NEVER commit real secrets.
# ============================================================

# --- Postgres (used by docker-compose.phi.yml) ---
# Password for the local PHI Postgres container. Dev-only default is "phi".
PHI_DB_PASSWORD=phi

# --- App-facing vars (copy these into repo-root .env.local) ---
# Connection string the Next.js app uses to reach the PHI Postgres.
DATABASE_URL_PHI=postgres://phi:phi@localhost:5433/phi

# Auth.js v5 secret — generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-openssl-rand-base64-32

# Canonical app URL for Auth.js callbacks (local dev).
AUTH_URL=http://localhost:3000

# App-layer field-encryption key (32-byte base64) for MBI/DOB/mfa_secret.
# Generate with: openssl rand -base64 32
# ⚠️ Dev-grade only. Production replaces this with an AWS KMS CMK (deferred).
PHI_ENC_KEY=replace-me-openssl-rand-base64-32

# Idle session timeout in minutes (HIPAA requires automatic logoff).
PHI_SESSION_IDLE_MINUTES=15
