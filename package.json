{
  "name": "agewell-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Compass AgeWell — website (Vite + React)",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "db:up": "docker compose -f backend/docker-compose.local.yml up -d",
    "db:down": "docker compose -f backend/docker-compose.local.yml down",
    "db:init": "npm --prefix backend/lead-handler run db:init",
    "backend:dev": "npm --prefix backend/lead-handler run dev"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^5.1.0",
    "vite": "^6.0.7"
  }
}
